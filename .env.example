# Coinbase Advanced Trade CDP credentials (required for live trading/validation; optional for booting API server)
# Create key in CDP Access: https://portal.cdp.coinbase.com/access/api
# CB_API_KEY_NAME must be full key resource name: organizations/{org_id}/apiKeys/{key_id}
CB_API_KEY_NAME=
CB_API_PRIVATE_KEY=

# Server
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# Operational mode
DRY_RUN=true
AUTHORITY=ASSIST
GLOBAL_KILL_SWITCH=false
CRYPTO_AUTO_ENABLED=true
STOCK_PAPER_ENABLED=true
KILL_SWITCH=false
ENABLE_CRYPTO=true
ENABLE_EQUITIES=true
CRYPTO_ALLOW_PYRAMIDING=false
STOCK_ALLOW_PYRAMIDING=false
TRADING_PAIRS=BTC-USD,ETH-USD,SOL-USD
STOCK_SYMBOLS=AAPL,NVDA,TSLA,SPY

# Risk configuration
MAX_PORTFOLIO_PCT_PER_TRADE=0.05
MAX_DOLLAR_LOSS_PER_TRADE=50
MAX_DAILY_LOSS_USD=150
STALE_PRICE_THRESHOLD_MS=30000
MAX_SPREAD_PCT=0.005
COOLDOWN_AFTER_STOP_MS=3600000
TAKE_PROFIT_PCT=0.04
STOP_LOSS_PCT=0.02
TRAILING_STOP_PCT=0.015

# Unified allocator
MAX_TOTAL_DAILY_LOSS_USD=150
MAX_CRYPTO_ALLOCATION=1
MAX_EQUITIES_ALLOCATION=0.4
PER_POSITION_MAX_RISK=0.02
TARGET_NOTIONAL_PCT=0.1

# Stock broker adapter (paper execution layer)
STOCK_BROKER_NAME=paper-stock
STOCK_MIN_ORDER_USD=1
STOCK_STARTING_CASH_USD=100000
STOCK_ANCHOR_AAPL=180
STOCK_ANCHOR_NVDA=900
STOCK_ANCHOR_TSLA=180
STOCK_ANCHOR_SPY=500
